{
  "name": "furnlo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose up chrome -d && npm run dev --workspace=apps/api & npm run dev --workspace=apps/web & stripe listen --forward-to localhost:4000/api/webhooks/stripe",
    "dev:api": "docker-compose up chrome -d && npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
