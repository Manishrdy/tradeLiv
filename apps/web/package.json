{
  "name": "@furnlo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build && npm run postbuild",
    "postbuild": "cp -r .next/static .next/standalone/apps/web/.next/static && cp -r public .next/standalone/apps/web/public",
    "start": "node .next/standalone/apps/web/server.js",
    "lint": "next lint"
  },
  "dependencies": {
    "@furnlo/types": "*",
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@stripe/stripe-js": "^4.9.0",
    "@stripe/react-stripe-js": "^3.1.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.1.0"
  }
}
