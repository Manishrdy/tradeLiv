# ─── Database ───────────────────────────────────────────────
# Toggle which database to use at runtime: "dev" or "prod"
USE_DB="dev"

DEV_DATABASE_URL="postgresql://user:password@host:5432/furnlo"
DEV_DATABASE_PASSWORD="enter_your_db_password"

PROD_DATABASE_URL="postgresql://user:password@host:5432/furnlo"
PROD_DATABASE_PASSWORD="enter_your_db_password"

# ─── Auth ────────────────────────────────────────────────────
# Minimum 32 characters; use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"
# Cross-subdomain cookies: production API + app on different hosts need SameSite=None + HTTPS.
# Omit or set lax/strict for local dev. Example production: AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SAME_SITE="none"
# Optional parent domain for cookies, e.g. .yourdomain.com (requires SameSite=None for cross-subdomain)
# AUTH_COOKIE_DOMAIN=
# Force secure cookies (default true in production unless AUTH_COOKIE_SECURE=false)
# AUTH_COOKIE_SECURE="true"

# ─── AI Provider ─────────────────────────────────────────────
# Which AI provider to use: "claude" | "gemini" | "agent-router"
USE_AI="claude"

CLAUDE_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-4-6"

AGENT_ROUTER_API_KEY="your-agent-router-api-key"
AGENT_ROUTER_MODEL="deepseek-r1-0528"

GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App ─────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── GitHub Issue Automation ─────────────────────────────────
GITHUB_ISSUES_ENABLED=true
GITHUB_OWNER="your-github-username"
GITHUB_REPO="your-repo-name"
GITHUB_TOKEN="github_pat_..."
GITHUB_ISSUE_LABEL="auto-bug"
GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# ─── Chat / Messaging ───────────────────────────────────
MESSAGE_TTL_DAYS=30

# ─── Browserless (headless Chrome for scraping) ─────────
BROWSER_WS_ENDPOINT="ws://localhost:3100"

# ─── Email (Zoho Mail) ───────────────────────────────────
# SMTP — for sending emails
SMTP_HOST="smtp.zoho.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your@zohomail.com"
SMTP_PASS="your-zoho-app-password"
EMAIL_FROM_NAME="tradeLiv"
EMAIL_FROM_ADDRESS="your@zohomail.com"

# IMAP — for reading/receiving emails (if needed)
IMAP_HOST="imap.zoho.com"
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER="your@zohomail.com"
IMAP_PASS="your-zoho-app-password"

# Admin email
ADMIN_EMAIL="admin@tradeliv.design"
