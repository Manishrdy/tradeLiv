{
  "name": "@furnlo/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run generate && rm -rf dist && tsc -p tsconfig.json && mkdir -p dist/generated && cp -R src/generated/client dist/generated/client",
    "generate": "./scripts/prisma.sh generate",
    "migrate": "./scripts/prisma.sh migrate deploy",
    "migrate:dev": "./scripts/prisma.sh migrate dev --name",
    "migrate:deploy": "./scripts/prisma.sh migrate deploy",
    "schema:check": "tsx scripts/check-schema.ts",
    "studio": "./scripts/prisma.sh studio",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "seed:admin": "dotenv -e ../../.env -- tsx src/seed-admin.ts"
  },
  "files": [
    "dist",
    "prisma"
  ],
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
