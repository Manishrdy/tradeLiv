generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DesignerStatus {
  pending_review
  approved
  rejected
  suspended
}

enum ProjectStatus {
  draft
  active
  ordered
  closed
}

enum ShortlistStatus {
  suggested
  approved
  rejected
  added_to_cart
  ordered
}

enum OrderStatus {
  draft
  submitted
  paid
  split_to_brands
  closed
}

enum BrandPOStatus {
  sent
  acknowledged
  in_production
  dispatched
  delivered
  cancelled
}

enum QuoteStatus {
  draft
  sent
  approved
  revision_requested
  expired
  converted
}

enum FeeType {
  percentage
  fixed
}

enum ActorType {
  designer
  client
  admin
  system
}

enum NotificationType {
  message
  quote_approved
  quote_revision
  quote_comment
  order_update
  shortlist_change
  client_portal_view
  payment_received
  application_approved
  application_rejected
}

enum AdminNotificationType {
  new_application
  designer_approved
  designer_rejected
  order_placed
  order_paid
  payment_failed
  brand_po_update
  system_alert
}

model Designer {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  fullName     String
  businessName String?
  phone        String?
  city         String?
  state        String?
  yearsOfExperience String?
  websiteUrl   String?
  linkedinUrl  String?
  instagramUrl String?
  referralSource   String?
  rejectionReason  String?
  status       DesignerStatus @default(pending_review)
  isAdmin      Boolean        @default(false)
  isSuperAdmin Boolean        @default(false)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  feeDefaults         Json?          // { taxRate, commissionType, commissionValue, platformFeeType, platformFeeValue }

  clients             Client[]
  projects            Project[]
  products            Product[]
  shortlistItems      ShortlistItem[]
  pinnedComparisons   PinnedComparison[]
  orders              Order[]
  quotes              Quote[]
  sessions            DesignerSession[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  adminNotifications  AdminNotification[]
}

model Client {
  id              String   @id @default(uuid())
  designerId      String
  name            String
  email           String?
  phone           String?
  billingAddress  Json?
  shippingAddress Json?
  createdAt       DateTime @default(now())

  designer Designer  @relation(fields: [designerId], references: [id])
  projects Project[]
}

model Project {
  id              String        @id @default(uuid())
  designerId      String
  clientId        String
  name            String
  description     String?
  status          ProjectStatus @default(draft)
  budgetMin       Decimal?
  budgetMax       Decimal?
  stylePreference String?
  portalToken     String?       @unique
  imageUrl        String?
  imageData       Bytes?
  imageMimeType   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  designer          Designer           @relation(fields: [designerId], references: [id])
  client            Client             @relation(fields: [clientId], references: [id])
  rooms             Room[]
  shortlistItems    ShortlistItem[]
  cartItems         CartItem[]
  orders            Order[]
  quotes            Quote[]
  pinnedComparisons PinnedComparison[]
  messages          Message[]
}

model Room {
  id                 String   @id @default(uuid())
  projectId          String
  name               String
  lengthFt           Decimal?
  widthFt            Decimal?
  heightFt           Decimal?
  areaSqft           Decimal?
  categoryNeeds      String[]
  budgetMin          Decimal?
  budgetMax          Decimal?
  clientRequirements Json?
  notes              String?
  createdAt          DateTime @default(now())

  project           Project            @relation(fields: [projectId], references: [id])
  shortlistItems    ShortlistItem[]
  cartItems         CartItem[]
  orderLineItems    OrderLineItem[]
  quoteLineItems    QuoteLineItem[]
  pinnedComparisons PinnedComparison[]
}

model Product {
  id               String   @id @default(uuid())
  designerId       String
  sourceUrl        String
  productName      String
  brandName        String?
  category         String?
  currency         String?  @default("USD")

  // Variant-aware fields
  variantId        String?          // Platform variant ID (e.g. Shopify variant ID)
  sku              String?          // ERP-level SKU
  activeVariant    Json?            // { finish: "X", size: "Y", price: 6200 }
  images           Json?            // { primary: url, gallery: [], note: "" }
  pricing          Json?            // [{ finish: "X", size: "Y", price: N }, ...]
  availableOptions Json?            // [{ type: "finish", values: [...] }, ...]
  features         String[]         // Top-level feature bullet points
  materials        Json?            // { primary: "", frame: "", certifications: [] }
  promotions       String[]         // ["30% off orders of $2,500+"]
  shipping         String?          // "Free shipping"
  availability     String?          // "In stock"

  // Kept from original schema
  price            Decimal?         // Legacy single price — will be removed after backfill
  imageUrl         String?          // Legacy single image — will be removed after backfill
  productUrl       String?
  dimensions       Json?
  material         String?          // Legacy flat material — will be removed after backfill
  finishes         String[]         // Legacy flat finishes — will be removed after backfill
  leadTime         String?
  metadata         Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  designer       Designer        @relation(fields: [designerId], references: [id])
  shortlistItems ShortlistItem[]
  cartItems      CartItem[]
  orderLineItems OrderLineItem[]
  quoteLineItems QuoteLineItem[]

  @@index([designerId, sourceUrl])
}

model ShortlistItem {
  id              String          @id @default(uuid())
  projectId       String
  roomId          String
  productId       String
  designerId      String
  selectedVariant Json?
  quantity        Int             @default(1)
  status          ShortlistStatus @default(suggested)
  designerNotes   String?
  clientNotes     String?
  sharedNotes     String?
  fitAssessment   String?
  priorityRank    Int?
  isPinned        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project  Project  @relation(fields: [projectId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  designer Designer @relation(fields: [designerId], references: [id])
}

model PinnedComparison {
  id                 String   @id @default(uuid())
  projectId          String
  roomId             String?
  designerId         String
  pinnedProductId    String
  comparedProductIds String[]
  createdAt          DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
  designer Designer @relation(fields: [designerId], references: [id])
}

model CartItem {
  id              String   @id @default(uuid())
  projectId       String
  productId       String
  roomId          String
  selectedVariant Json?
  quantity        Int
  unitPrice       Decimal?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
}

model Order {
  id              String      @id @default(uuid())
  projectId       String
  designerId      String
  status          OrderStatus @default(draft)
  totalAmount     Decimal?
  taxAmount       Decimal?
  stripePaymentId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project   Project              @relation(fields: [projectId], references: [id])
  designer  Designer             @relation(fields: [designerId], references: [id])
  lineItems OrderLineItem[]
  brandPOs  BrandPurchaseOrder[]
  payments  Payment[]
}

model OrderLineItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  brandPoId       String?
  roomId          String
  selectedVariant Json?
  quantity        Int
  unitPrice       Decimal?
  lineTotal       Decimal?

  order   Order               @relation(fields: [orderId], references: [id])
  product Product             @relation(fields: [productId], references: [id])
  brandPO BrandPurchaseOrder? @relation(fields: [brandPoId], references: [id])
  room    Room                @relation(fields: [roomId], references: [id])
}

model BrandPurchaseOrder {
  id        String        @id @default(uuid())
  orderId   String
  brandName String
  status    BrandPOStatus @default(sent)
  subtotal  Decimal?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  order     Order           @relation(fields: [orderId], references: [id])
  lineItems OrderLineItem[]
}

model Payment {
  id                    String   @id @default(uuid())
  orderId               String
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?  @unique
  amount                Decimal
  currency              String   @default("usd")
  status                String   @default("pending")
  paymentMethod         String?
  stripeResponse        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Quote {
  id               String      @id @default(uuid())
  projectId        String
  designerId       String
  version          Int         @default(1)
  status           QuoteStatus @default(draft)
  title            String?
  notes            String?

  // Fee configuration
  taxRate          Decimal?    // e.g. 8.25 for 8.25%
  commissionType   FeeType?
  commissionValue  Decimal?    // percentage value or fixed dollar amount
  platformFeeType  FeeType?
  platformFeeValue Decimal?

  // Computed totals (recalculated on save)
  subtotal          Decimal?
  taxAmount         Decimal?
  commissionAmount  Decimal?
  platformFeeAmount Decimal?
  grandTotal        Decimal?

  sentAt           DateTime?
  approvedAt       DateTime?
  expiresAt        DateTime?
  convertedOrderId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project   Project         @relation(fields: [projectId], references: [id])
  designer  Designer        @relation(fields: [designerId], references: [id])
  lineItems QuoteLineItem[]
  comments  QuoteComment[]

  @@index([projectId, status])
  @@index([designerId])
}

model QuoteLineItem {
  id              String   @id @default(uuid())
  quoteId         String
  productId       String
  roomId          String
  selectedVariant Json?
  quantity        Int
  unitPrice       Decimal  // Snapshot of product retail price
  lineTotal       Decimal  // unitPrice * quantity + adjustmentValue
  adjustmentLabel String?  // e.g. "Volume discount", "Rush surcharge"
  adjustmentValue Decimal? // Positive = surcharge, negative = discount
  sortOrder       Int      @default(0)

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
}

model QuoteComment {
  id         String    @id @default(uuid())
  quoteId    String
  senderType ActorType
  senderId   String?
  senderName String
  text       String
  lineItemId String?   // Optional: links comment to a specific line item
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, createdAt])
}

model Message {
  id          String    @id @default(uuid())
  projectId   String
  senderType  ActorType
  senderId    String?
  senderName  String
  text        String
  contextType String?   // "quote", "room", "order", "general"
  contextId   String?   // e.g. quoteId, roomId, orderId
  metadata    Json?     // e.g. { lineItemId: "..." }
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, senderType, readAt])
  @@index([projectId, contextType, contextId])
}

model Notification {
  id           String           @id @default(uuid())
  designerId   String
  type         NotificationType
  title        String
  body         String?
  projectId    String?
  resourceType String?          // "quote", "order", "message", "shortlist"
  resourceId   String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())

  designer Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)

  @@index([designerId, read, createdAt])
  @@index([designerId, createdAt])
}

model AdminNotification {
  id           String                @id @default(uuid())
  type         AdminNotificationType
  title        String
  body         String?
  designerId   String?               // the designer this notification is about
  read         Boolean               @default(false)
  createdAt    DateTime              @default(now())

  designer     Designer?             @relation(fields: [designerId], references: [id], onDelete: SetNull)

  @@index([read, createdAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  actorType  ActorType
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  payload    Json?
  createdAt  DateTime  @default(now())
}

model FurnitureCategory {
  id        String  @id @default(uuid())
  name      String  @unique
  group     String?
  icon      String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
  createdAt DateTime @default(now())
}

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  label     String
  group     String   @default("general")
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model RefreshToken {
  id          String   @id @default(uuid())
  designerId  String
  tokenHash   String   @unique
  family      String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  userAgent   String?
  ipAddress   String?

  designer Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)

  @@index([designerId])
  @@index([family])
  @@index([expiresAt])
}

model DesignerSession {
  id         String    @id @default(uuid())
  designerId String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  durationMs Int?
  lastPing   DateTime  @default(now())
  userAgent  String?

  designer Designer @relation(fields: [designerId], references: [id])

  @@index([designerId, startedAt])
  @@index([designerId, lastPing])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leads {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  name       String
  email      String    @unique
  phone      String
  user_type  String
}
