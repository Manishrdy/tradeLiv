generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DesignerStatus {
  pending_review
  approved
  rejected
  suspended
}

enum ProjectStatus {
  draft
  active
  ordered
  closed
}

enum ShortlistStatus {
  suggested
  approved
  rejected
  added_to_cart
  ordered
}

enum OrderStatus {
  draft
  submitted
  paid
  split_to_brands
  closed
}

enum BrandPOStatus {
  sent
  acknowledged
  in_production
  dispatched
  delivered
  cancelled
}

enum ActorType {
  designer
  client
  admin
  system
}

model Designer {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  fullName     String
  businessName String?
  phone        String?
  status       DesignerStatus @default(pending_review)
  isAdmin      Boolean        @default(false)
  isSuperAdmin Boolean        @default(false)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  clients             Client[]
  projects            Project[]
  products            Product[]
  shortlistItems      ShortlistItem[]
  pinnedComparisons   PinnedComparison[]
  orders              Order[]
  sessions            DesignerSession[]
  refreshTokens       RefreshToken[]
}

model Client {
  id              String   @id @default(uuid())
  designerId      String
  name            String
  email           String?
  phone           String?
  billingAddress  Json?
  shippingAddress Json?
  createdAt       DateTime @default(now())

  designer Designer  @relation(fields: [designerId], references: [id])
  projects Project[]
}

model Project {
  id              String        @id @default(uuid())
  designerId      String
  clientId        String
  name            String
  description     String?
  status          ProjectStatus @default(draft)
  budgetMin       Decimal?
  budgetMax       Decimal?
  stylePreference String?
  portalToken     String?       @unique
  imageUrl        String?
  imageData       Bytes?
  imageMimeType   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  designer          Designer           @relation(fields: [designerId], references: [id])
  client            Client             @relation(fields: [clientId], references: [id])
  rooms             Room[]
  shortlistItems    ShortlistItem[]
  cartItems         CartItem[]
  orders            Order[]
  pinnedComparisons PinnedComparison[]
  messages          Message[]
}

model Room {
  id                 String   @id @default(uuid())
  projectId          String
  name               String
  lengthFt           Decimal?
  widthFt            Decimal?
  heightFt           Decimal?
  areaSqft           Decimal?
  categoryNeeds      String[]
  budgetMin          Decimal?
  budgetMax          Decimal?
  clientRequirements Json?
  notes              String?
  createdAt          DateTime @default(now())

  project           Project            @relation(fields: [projectId], references: [id])
  shortlistItems    ShortlistItem[]
  cartItems         CartItem[]
  orderLineItems    OrderLineItem[]
  pinnedComparisons PinnedComparison[]
}

model Product {
  id          String   @id @default(uuid())
  designerId  String
  sourceUrl   String
  productName String
  brandName   String?
  price       Decimal?
  imageUrl    String?
  productUrl  String?
  dimensions  Json?
  material    String?
  finishes    String[]
  leadTime    String?
  metadata    Json?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designer       Designer        @relation(fields: [designerId], references: [id])
  shortlistItems ShortlistItem[]
  cartItems      CartItem[]
  orderLineItems OrderLineItem[]

  @@index([designerId, sourceUrl])
}

model ShortlistItem {
  id              String          @id @default(uuid())
  projectId       String
  roomId          String
  productId       String
  designerId      String
  selectedVariant Json?
  quantity        Int             @default(1)
  status          ShortlistStatus @default(suggested)
  designerNotes   String?
  clientNotes     String?
  sharedNotes     String?
  fitAssessment   String?
  priorityRank    Int?
  isPinned        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project  Project  @relation(fields: [projectId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  designer Designer @relation(fields: [designerId], references: [id])
}

model PinnedComparison {
  id                 String   @id @default(uuid())
  projectId          String
  roomId             String?
  designerId         String
  pinnedProductId    String
  comparedProductIds String[]
  createdAt          DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id])
  room     Room?    @relation(fields: [roomId], references: [id])
  designer Designer @relation(fields: [designerId], references: [id])
}

model CartItem {
  id              String   @id @default(uuid())
  projectId       String
  productId       String
  roomId          String
  selectedVariant Json?
  quantity        Int
  unitPrice       Decimal?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
}

model Order {
  id              String      @id @default(uuid())
  projectId       String
  designerId      String
  status          OrderStatus @default(draft)
  totalAmount     Decimal?
  taxAmount       Decimal?
  stripePaymentId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project   Project              @relation(fields: [projectId], references: [id])
  designer  Designer             @relation(fields: [designerId], references: [id])
  lineItems OrderLineItem[]
  brandPOs  BrandPurchaseOrder[]
  payments  Payment[]
}

model OrderLineItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  brandPoId       String?
  roomId          String
  selectedVariant Json?
  quantity        Int
  unitPrice       Decimal?
  lineTotal       Decimal?

  order   Order               @relation(fields: [orderId], references: [id])
  product Product             @relation(fields: [productId], references: [id])
  brandPO BrandPurchaseOrder? @relation(fields: [brandPoId], references: [id])
  room    Room                @relation(fields: [roomId], references: [id])
}

model BrandPurchaseOrder {
  id        String        @id @default(uuid())
  orderId   String
  brandName String
  status    BrandPOStatus @default(sent)
  subtotal  Decimal?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  order     Order           @relation(fields: [orderId], references: [id])
  lineItems OrderLineItem[]
}

model Payment {
  id                    String   @id @default(uuid())
  orderId               String
  stripeSessionId       String?  @unique
  stripePaymentIntentId String?  @unique
  amount                Decimal
  currency              String   @default("usd")
  status                String   @default("pending")
  paymentMethod         String?
  stripeResponse        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Message {
  id         String    @id @default(uuid())
  projectId  String
  senderType ActorType
  senderId   String?
  senderName String
  text       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
  @@index([projectId, senderType, readAt])
}

model AuditLog {
  id         String    @id @default(uuid())
  actorType  ActorType
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  payload    Json?
  createdAt  DateTime  @default(now())
}

model FurnitureCategory {
  id        String  @id @default(uuid())
  name      String  @unique
  group     String?
  icon      String?
  sortOrder Int     @default(0)
  active    Boolean @default(true)
  createdAt DateTime @default(now())
}

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  label     String
  group     String   @default("general")
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model RefreshToken {
  id          String   @id @default(uuid())
  designerId  String
  tokenHash   String   @unique
  family      String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  userAgent   String?
  ipAddress   String?

  designer Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)

  @@index([designerId])
  @@index([family])
  @@index([expiresAt])
}

model DesignerSession {
  id         String    @id @default(uuid())
  designerId String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  durationMs Int?
  lastPing   DateTime  @default(now())
  userAgent  String?

  designer Designer @relation(fields: [designerId], references: [id])

  @@index([designerId, startedAt])
  @@index([designerId, lastPing])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leads {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  name       String
  email      String    @unique
  phone      String
  user_type  String
}
