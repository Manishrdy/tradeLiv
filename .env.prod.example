# ─── Production Environment Template ─────────────────────────────────────────
# Copy this to .env.prod on your OCI VM and fill in all values.
# This file is loaded by docker-compose.prod.yml via env_file: .env.prod
# NEVER commit .env.prod to git.

# ─── Database ────────────────────────────────────────────────────────────────
USE_DB=prod
PROD_DATABASE_URL=postgresql://user:password@host:5432/tradeliv
PROD_DATABASE_PASSWORD=your_strong_db_password

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=replace_with_64_char_random_string
JWT_ACCESS_EXPIRES_IN=15m

# Cross-domain cookie settings (required when API + app are on different subdomains)
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_DOMAIN=.yourdomain.com
AUTH_COOKIE_SECURE=true

# ─── AI Provider ─────────────────────────────────────────────────────────────
USE_AI=claude
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ─────────────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# ─── GitHub Issue Automation ─────────────────────────────────────────────────
GITHUB_ISSUES_ENABLED=true
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=github_pat_...
GITHUB_ISSUE_LABEL=auto-bug
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ─── Email (Zoho Mail) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@zohomail.com
SMTP_PASS=your-zoho-app-password
EMAIL_FROM_NAME=tradeLiv
EMAIL_FROM_ADDRESS=your@zohomail.com
IMAP_HOST=imap.zoho.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your@zohomail.com
IMAP_PASS=your-zoho-app-password
ADMIN_EMAIL=admin@tradeliv.design

# ─── Chat ────────────────────────────────────────────────────────────────────
MESSAGE_TTL_DAYS=30

# ─── Database Backups ────────────────────────────────────────────────────────
BACKUP_DIR=/app/db-backups
